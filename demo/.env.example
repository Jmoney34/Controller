# Copy this file to ".env" and fill in your two values.
# (.env is git-ignored — your credentials never get committed.)

# Your GoHighLevel Private Integration Token (read scopes are enough for the demo).
# GHL > Settings > Private Integrations > Create new token.
# Recommended read scopes: View Contacts, View Opportunities, View Payments, View Locations.
GHL_TOKEN=

# Your GHL Location ID.
# Find it in GHL > Settings > Business Profile, or in your dashboard URL:
# https://app.gohighlevel.com/v2/location/<THIS_PART_IS_YOUR_LOCATION_ID>/dashboard
GHL_LOCATION_ID=
